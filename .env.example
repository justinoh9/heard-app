EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Spotify Web API — powers music search (src/music/spotify.ts). Two modes:
#
# Mode 1 — PROXY (recommended, secret never ships): deploy the Edge Function in
# supabase/functions/spotify-token (see its README), then set only this to its
# URL and leave the CLIENT_SECRET below blank. Keep the Supabase anon key set.
EXPO_PUBLIC_SPOTIFY_TOKEN_URL=
#
# Mode 2 — DIRECT (quick start, zero backend): create an app at
# https://developer.spotify.com/dashboard and paste its Client ID + secret.
# SECURITY: EXPO_PUBLIC_* values are inlined into the client bundle, so the
# secret below IS exposed to anyone who downloads the app. Fine for a demo (same
# trust level as the Supabase anon key); switch to Mode 1 before a real launch.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=
