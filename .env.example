EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Spotify Web API — powers music search (src/music/spotify.ts).
# Create an app at https://developer.spotify.com/dashboard and copy its
# Client ID and Client secret here.
#
# SECURITY: EXPO_PUBLIC_* values are inlined into the client bundle, so the
# secret below IS exposed to anyone who downloads the app. That's acceptable
# for this prototype (same trust level as the Supabase anon key), but before a
# real launch move token minting to a backend so the secret never ships.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=
